{
  "version": 2,
  "buildCommand": "npm run db:generate --workspace=backend && npm run build --workspace=frontend",
  "builds": [
    {
      "src": "backend/src/index.ts",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/next.config.js",
      "use": "@vercel/next"
    }
  ],
  "outputDirectory": "frontend/.next",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/backend/src/index.ts"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend"
    }
  ]
}
